# OpenSourceMate backend — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit it.

# --- Database ---
# Local dev (no password, peer auth):
#   DATABASE_URL=postgresql://opensource@localhost/opensourcemate
# Production format:
#   DATABASE_URL=postgresql://<user>:<pass>@<host>/<db>
DATABASE_URL=postgresql://opensource@localhost/opensourcemate

# --- JWT ---
# Generate with:  openssl rand -hex 32
SECRET_KEY=change-this-secret-in-production

# --- CORS ---
# Comma-separated list of frontend origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- GitHub OAuth (optional) ---
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL must EXACTLY match GITHUB_CALLBACK_URL.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://127.0.0.1:8000/auth/github/callback
GITHUB_SCOPES=read:user user:email repo

# Where the backend should redirect users after the GitHub OAuth callback.
FRONTEND_URL=http://localhost:3000

# --- LLM (AI analysis) ---
# Provider options: cloudflare | openai | groq | ollama (anything OpenAI-compatible)
#
# === Cloudflare Workers AI (recommended — free tier 10K Neurons/day) ===
# 1. Account ID: https://dash.cloudflare.com → right sidebar
# 2. API token : https://dash.cloudflare.com/profile/api-tokens → "Workers AI" template
LLM_PROVIDER=cloudflare
LLM_BASE_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_CF_ACCOUNT_ID/ai/v1
LLM_MODEL=@cf/meta/llama-3.1-8b-instruct
LLM_API_KEY=YOUR_CF_API_TOKEN

# === Alternative: OpenAI ===
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-proj-xxxx
# (Or use OPENAI_API_KEY=sk-... — the backend reads either name.)
