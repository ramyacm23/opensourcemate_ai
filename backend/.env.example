# OpenSourceMate backend — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit it.

# --- Database ---
# Local dev (no password, peer auth):
#   DATABASE_URL=postgresql://opensource@localhost/opensourcemate
# Production format:
#   DATABASE_URL=postgresql://<user>:<pass>@<host>/<db>
DATABASE_URL=postgresql://opensource@localhost/opensourcemate

# --- JWT ---
# Generate with:  openssl rand -hex 32
SECRET_KEY=change-this-secret-in-production

# --- CORS ---
# Comma-separated list of frontend origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- GitHub OAuth (optional) ---
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL must EXACTLY match GITHUB_CALLBACK_URL.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://127.0.0.1:8000/auth/github/callback
GITHUB_SCOPES=read:user user:email repo

# Where the backend should redirect users after the GitHub OAuth callback.
FRONTEND_URL=http://localhost:3000
